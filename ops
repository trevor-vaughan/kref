 internal/entry/operations_test.go\ngit commit -m \"feat(entry): add SetTitle operation\"\n```\n\n## Task B2: `store.Update` appends body/title ops to an existing entry (spec §5)\n\n**Files:**\n- Modify: `internal/store/store.go`\n- Test: `internal/store/store_test.go`\n\n- [ ] **Step 1: Write the failing test**\n\n```go\nvar _ = Describe(\"Store update\", func() {\n\tIt(\"appends body and title changes to an existing entry\", func() {\n\t\tdir := gitRepo()\n\t\ts, err := Init(dir, \"T\", \"t@e.com\")\n\t\tExpect(err).NotTo(HaveOccurred())\n\t\tDeferCleanup(func() { _ = s.Close() })\n\t\tid, err := s.Add(entry.TierShared, \"document\", \"Title v1\", \"body v1\")\n\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\tExpect(s.Update(id, \"body v2\", \"Title v2\")).To(Succeed())\n\n\t\tgot, err := s.Get(id)\n\t\tExpect(err).NotTo(HaveOccurred())\n\t\tExpect(got.Body).To(Equal(\"body v2\"))\n\t\tExpect(got.Title).To(Equal(\"Title v2\"))\n\t})\n})\n```\n\n- [ ] **Step 2: Run — verify fail**\n\nRun: `go test ./internal/store/`\nExpected: FAIL — `Update` undefined.\n\n- [ ] **Step 3: Implement `Update`**\n\nAdd to `internal/store/store.go`:\n\n```go\n// Update appends a body (and, if changed, title) op to an existing entry,\n// searching every tier. It is the mutating half of marker-based re-ingest.\nfunc (s *Store) Update(id entity.Id, body, title string) error {\n\tfor _, t := range entry.AllTiers() {\n\t\te, err := entry.Read(s.repo, t, id)\n\t\tif err != nil {\n\t\t\tif entity.IsErrNotFound(err) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treturn fmt.Errorf(\"read %s: %w\", id, err)\n\t\t}\n\t\tsnap := e.Compile()\n\t\tchanged := false\n\t\tif body != snap.Body {\n\t\t\te.Append(entry.NewSetBody(s.author, body))\n\t\t\tchanged = true\n\t\t}\n\t\tif title != \"\" \u0026\u0026 title != snap.Title {\n\t\t\te.Append(entry.NewSetTitle(s.author, title))\n\t\t\tchanged = true\n\t\t}\n\t\tif !changed {\n\t\t\treturn nil\n\t\t}\n\t\treturn e.Commit(s.repo)\n\t}\n\treturn fmt.Errorf(\"entry %s not found\", id)\n}\n```\n\n- [ ] **Step 4: Run — verify pass**\n\nRun: `go test ./internal/store/`\nExpected: PASS.\n\n- [ ] **Step 5: Commit**\n\n```bash\ngit add internal/store/store.go internal/store/store_test.go\ngit commit -m \"feat(store): Update appends body/title ops to an existing entry\"\n```\n\n## Task B3: Marker parse/strip/stamp helpers in bridge (spec D1)\n\n**Files:**\n- Modify: `internal/bridge/bridge.go`\n- Test: `internal/bridge/marker_test.go` (new)\n\n- [ ] **Step 1: Write the failing test**\n\nCreate `internal/bridge/marker_test.go`:\n\n```go\npackage bridge\n\nimport (\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n)\n\nvar _ = Describe(\"kref-id marker\", func() {\n\tconst id = \"0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef\"\n\n\tIt(\"returns empty id and the original body when absent\", func() {\n\t\tgotID, body := splitMarker([]byte(\"# Title\\nprose\\n\"))\n\t\tExpect(gotID).To(BeEmpty())\n\t\tExpect(string(body)).To(Equal(\"# Title\\nprose\\n\"))\n\t})\n\n\tIt(\"extracts the id and strips the trailer\", func() {\n\t\traw := []byte(\"# Title\\nprose\\n\\n\u003c!-- kref-id: \" + id + \" --\u003e\\n\")\n\t\tgotID, body := splitMarker(raw)\n\t\tExpect(gotID).To(Equal(id))\n\t\tExpect(string(body)).To(Equal(\"# Title\\nprose\\n\"))\n\t})\n\n\tIt(\"ignores a marker whose id is not 64 hex chars\", func() {\n\t\tgotID, _ := splitMarker([]byte(\"x\\n\\n\u003c!-- kref-id: short --\u003e\\n\"))\n\t\tExpect(gotID).To(BeEmpty())\n\t})\n\n\tIt(\"appends a well-formed trailer\", func() {\n\t\tout := withMarker([]byte(\"# Title\\nprose\\n\"), id)\n\t\tgotID, body := splitMarker(out)\n\t\tExpect(gotID).To(Equal(id))\n\t\tExpect(string(body)).To(Equal(\"# Title\\nprose\\n\"))\n\t})\n})\n```\n\n- [ ] **Step 2: Run — verify fail**\n\nRun: `go test ./internal/bridge/`\nExpected: FAIL — `splitMarker`/`withMarker` undefined.\n\n- [ ] **Step 3: Implement the helpers**\n\nAdd to `internal/bridge/bridge.go` (and add `\"regexp\"` to imports):\n\n```go\n// markerRe matches a kref-id trailer: an HTML comment carrying a 64-hex id,\n// alone on the last non-empty line of the file.\nvar markerRe = regexp.MustCompile(`(?m)^[ \\t]*\u003c!--[ \\t]*kref-id:[ \\t]*([0-9a-fA-F]{64})[ \\t]*--\u003e[ \\t]*$`)\n\n// splitMarker returns the last well-formed kref-id in content (or \"\" if none) and\n// the body with that trailer line and a single trailing blank line removed.\nfunc splitMarker(content []byte) (string, []byte) {\n\tlocs := markerRe.FindAllSubmatchIndex(content, -1)\n\tif len(locs) == 0 {\n\t\treturn \"\", content\n\t}\n\tlast := locs[len(locs)-1]\n\tid := string(content[last[2]:last[3]])\n\t// Drop from the start of the marker line; also drop one preceding newline\n\t// (and a blank separator line) so re-stamping round-trips exactly.\n\tcut := last[0]\n\tbody := content[:cut]\n\tbody = bytes.TrimRight(body, \"\\n\")\n\tif len(body) \u003e 0 {\n\t\tbody = append(body, '\\n')\n\t}\n\treturn id, body\n}\n\n// withMarker returns body with a kref-id trailer appended (blank line + comment).\nfunc withMarker(body []byte, id string) []byte {\n\tout := bytes.TrimRight(body, \"\\n\")\n\treturn append(out, []byte(\"\\n\\n\u003c!-- kref-id: \"+id+\" --\u003e\\n\")...)\n}\n```\n\n- [ ] **Step 4: Run — verify pass**\n\nRun: `go test ./internal/bridge/`\nExpected: PASS.\n\n- [ ] **Step 5: Commit**\n\n```bash\ngit add internal/bridge/bridge.go internal/bridge/marker_test.go\ngit commit -m \"feat(bridge): kref-id trailer marker parse/strip/stamp helpers\"\n```\n\n## Task B4: Idempotent `Ingest` state machine (spec D2/D3)\n\n**Files:**\n- Modify: `internal/bridge/bridge.go`\n- Test: `internal/bridge/bridge_test.go`\n\n- [ ] **Step 1: Extend `IngestResult` and write failing tests**\n\nChange `IngestResult` to carry the source path and action, and add specs. First, the struct:\n\n```go\n// IngestResult reports the outcome of ingesting one file.\ntype IngestResult struct {\n\tPath        string\n\tID      