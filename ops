 snap.ContentType, color, cw)\n\t\treturn strings.Split(strings.TrimRight(b.String(), \"\\n\"), \"\\n\")\n\t}\n\td := numDigits(len(renderAt(width)))\n\tvar lines []string\n\tfor i := 0; i \u003c 4; i++ {\n\t\tlines = renderAt(width - (d + 3))\n\t\tnd := numDigits(len(lines))\n\t\tif nd == d {\n\t\t\tbreak\n\t\t}\n\t\td = nd\n\t}\n\treturn lines, d + 3\n}\n\n// showPaged composes the header and body and runs the interactive pager. The\n// header is rendered un-numbered above a numbered body (fancy mode only).\nfunc showPaged(snap *entry.Snapshot, opts render.ShowOptions) error {\n\ttitle := render.ShortID(snap.ID) + \"  \" + snap.Title\n\tvar header []string\n\tif !opts.NoHeader {\n\t\tvar hb bytes.Buffer\n\t\trender.ShowHeader(\u0026hb, snap, opts.Color, opts.TrackedNote)\n\t\theader = strings.Split(strings.TrimRight(hb.String(), \"\\n\"), \"\\n\")\n\t\theader = append(header, \"\") // blank line between header and body\n\t}\n\tpc := pagerContent{title: title, header: header}\n\tif opts.Raw {\n\t\tpc.body = strings.Split(strings.TrimRight(snap.Body, \"\\n\"), \"\\n\")\n\t} else {\n\t\tpc.body, pc.gutterW = renderPagerBody(snap, opts.Color, opts.Width)\n\t\tpc.number = true\n\t}\n\treturn Page(pc)\n}\n```\n\nRewrite the tail of `newShowCmd`'s `RunE` (from the `opts :=` line through the final `return nil`), removing the trailing `Tracked:` append:\n\n```go\n\t\t\topts := render.ShowOptions{\n\t\t\t\tRaw:      raw,\n\t\t\t\tNoHeader: noHeader,\n\t\t\t\tColor:    useColor(cmd),\n\t\t\t\tWidth:    ttyWidth(),\n\t\t\t}\n\t\t\tif snap.Tracked {\n\t\t\t\topts.TrackedNote = snap.TrackedPath + \" [\" + drift + \"]\"\n\t\t\t}\n\t\t\tif usePager(cmd) \u0026\u0026 !noPager {\n\t\t\t\treturn showPaged(snap, opts)\n\t\t\t}\n\t\t\tvar buf bytes.Buffer\n\t\t\trender.Show(\u0026buf, snap, opts)\n\t\t\tfmt.Fprint(cmd.OutOrStdout(), buf.String())\n\t\t\treturn nil\n```\n\n- [ ] **Step 3: Run the full suite + build**\n\nRun: `task test`\nExpected: PASS (no caller now passes only `Page(