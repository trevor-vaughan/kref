rect; promote to direct)\n\n- [ ] **Step 1: Write the failing test**\n\n```go\nvar _ = Describe(\"Merge\", func() {\n\tIt(\"preserves foreign hooks and replaces only kref-* commands\", func() {\n\t\texisting := `pre-commit:\n  commands:\n    lint:\n      run: npm run lint\npost-merge:\n  commands:\n    kref-sync-pull:\n      run: /old/kref sync pull\n`\n\t\tmerged, err := Merge([]byte(existing), Render(\"/abs/bin/kref\"))\n\t\tExpect(err).NotTo(HaveOccurred())\n\t\tExpect(string(merged)).To(ContainSubstring(\"npm run lint\"))      // foreign kept\n\t\tExpect(string(merged)).To(ContainSubstring(\"/abs/bin/kref sync pull\")) // kref refreshed\n\t\tExpect(string(merged)).NotTo(ContainSubstring(\"/old/kref\"))        // stale kref gone\n\t\tExpect(string(merged)).To(ContainSubstring(\"post-commit:\"))      // new kref hook added\n\t})\n\n\tIt(\"returns the generated config verbatim when there is no existing file\", func() {\n\t\tmerged, err := Merge(nil, Render(\"/abs/bin/kref\"))\n\t\tExpect(err).NotTo(HaveOccurred())\n\t\tExpect(string(merged)).To(Equal(Render(\"/abs/bin/kref\")))\n\t})\n})\n```\n\n- [ ] **Step 2: Run — verify fail**\n\nRun: `go test ./internal/hooks/`\nExpected: FAIL — `Merge` undefined.\n\n- [ ] **Step 3: Implement `Merge`**\n\nAdd to `internal/hooks/hooks.go` (add `\"strings\"` and `\"gopkg.in/yaml.v3\"` to imports).\n\n\u003e **Verified API:** `gopkg.in/yaml.v3@v3.0.1` has **no** `MapSlice`/`MapItem` (that was yaml.v2). Use `yaml.Node` — a `MappingNode` stores alternating key/value nodes in `.Content`, preserving order and the user's comments through a round-trip. Kind constants: `yaml.DocumentNode`, `yaml.MappingNode`, `yaml.ScalarNode`.\n\nStrategy: parse both configs into `yaml.Node` document trees; for each hook in the generated config, replace only the `kref-*` keys under that hook's `commands`, preserving every other hook and command (and the existing file's comments).\n\n```go\n// Merge folds kref's managed commands (every command whose key starts with \"kref-\")\n// from generated into existing, preserving all other hooks, commands, and the\n// existing file's comments/order. When existing is empty it returns generated\n// unchanged.\nfunc Merge(existing []byte, generated string) ([]byte, error) {\n\tif strings.TrimSpace(string(existing)) == \"\" {\n\t\treturn []byte(generated), nil\n\t}\n\tvar curDoc, genDoc yaml.Node\n\tif err := yaml.Unmarshal(existing, \u0026curDoc); err != nil {\n\t\treturn nil, fmt.Errorf(\"parse existing lefthook.yml: %w\", err)\n\t}\n\tif err := yaml.Unmarshal([]byte(generated), \u0026genDoc); err != nil {\n\t\treturn nil, fmt.Errorf(\"parse generated config: %w\", err)\n\t}\n\tcurRoot, genRoot := mappingRoot(\u0026curDoc), mappingRoot(\u0026genDoc)\n\tif curRoot == nil || genRoot == nil {\n\t\treturn nil, fmt.Errorf(\"lefthook config is not a YAML mapping\")\n\t}\n\tfor i := 0; i+1 \u003c len(genRoot.Content); i += 2 {\n\t\thookKey, hookVal := genRoot.Content[i], genRoot.Content[i+1]\n\t\tif curHook := mapGet(curRoot, hookKey.Value); curHook != nil {\n\t\t\tmergeHookCommands(curHook, hookVal)\n\t\t} else {\n\t\t\tcurRoot.Content = append(curRoot.Content, hookKey, hookVal) // hook absent: add wholesale\n\t\t}\n\t}\n\tout, err := yaml.Marshal(\u0026curDoc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn out, nil\n}\n\n// mappingRoot returns the root mapping node of a parsed YAML document, or nil.\nfunc mappingRoot(doc *yaml.Node) *yaml.Node {\n\tif doc.Kind == yaml.DocumentNode \u0026\u0026 len(doc.Content) == 1 \u0026\u0026 doc.Content[0].Kind == yaml.MappingNode {\n\t\treturn doc.Content[0]\n\t}\n\treturn nil\n}\n\n// mapGet returns the value node for key in a mapping node, or nil.\nfunc mapGet(m *yaml.Node, key string) *yaml.Node {\n\tfor i := 0; i+1 \u003c len(m.Content); i += 2 {\n\t\tif m.Content[i].Value == key {\n\t\t\treturn m.Content[i+1]\n\t\t}\n\t}\n\treturn nil\n}\n\n// mergeHookCommands replaces kref-* command entries under curHook's `commands`\n// mapping with those from genHook, preserving foreign commands.\nfunc mergeHookCommands(curHook, genHook *yaml.Node) {\n\tgenCmds := mapGet(genHook, \"commands\")\n\tif genCmds == nil {\n\t\treturn\n\t}\n\tcurCmds := mapGet(curHook, \"commands\")\n\tif curCmds == nil {\n\t\tcurHook.Content = append(curHook.Content,\n\t\t\t\u0026yaml.Node{Kind: yaml.ScalarNode, Value: \"commands\"}, genCmds)\n\t\treturn\n\t}\n\tkept := make([]*yaml.Node, 0, len(curCmds.Content))\n\tfor i := 0; i+1 \u003c len(curCmds.Content); i += 2 {\n\t\tif !strings.HasPrefix(curCmds.Content[i].Value, \"kref-\") {\n\t\t\tkept = append(kept, curCmds.Content[i], curCmds.Content[i+1])\n\t\t}\n\t}\n\tfor i := 0; i+1 \u003c len(genCmds.Content); i += 2 {\n\t\tkept = append(kept, genCmds.Content[i], genCmds.Content[i+1])\n\t}\n\tcurCmds.Content = kept\n}\n```\n\n- [ ] **Step 4: Run — verify pass and promote the dep**\n\nRun: `go test ./internal/hooks/`\nExpected: PASS.\nThen: `go mod tidy` (moves `gopkg.in/yaml.v3` from indirect to direct).\nRun: `go build ./...`\nExpected: clean.\n\n- [ ] **Step 5: Wire the CLI to merge + use `os.Executable`**\n\nIn `cmd/kref/commands.go` `newHooksCmd`, rewrite the `install` and `print` RunE bodies. `install`:\n\n```go\n\t\tRunE: func(cmd *cobra.Command, _ []string) error {\n\t\t\texe, err := os.Executable()\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tgenerated := hooks.Render(exe)\n\t\t\tpath := filepath.Join(*dir, hooks.InstallPath)\n\t\t\texisting, statErr := os.ReadFile(path)\n\t\t\tif statErr != nil \u0026\u0026 !os.IsNotExist(statErr) {\n\t\t\t\treturn statErr\n\t\t\t}\n\t\t\tif statErr == nil \u0026\u0026 !force {\n\t\t\t\treturn fmt.Errorf(\"%s already exists (use --force to merge kref's hooks into it)\", path)\n\t\t\t}\n\t\t\tcontent, err := hooks.Merge(existing, generated)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err := os.WriteFile(path, content, 0o644); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\treturn writeJSON(cmd, map[string]string{\"status\": \"installed\", \"path\": path})\n\t\t},\n```\n\nUpdate the `--force` flag help to: `\"merge kref's hooks into an existing lefthook.yml\"`. And `print`:\n\n```go\n\t\tRunE: func(cmd *cobra.Command, _ []string) error {\n\t\t\texe, err := os.Executable()\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tfmt.Fprint(cmd.OutOrStdout(), hooks.Render(exe))\n\t\t\treturn nil\n\t\t},\n```\n\n- [ ] **Step 6: Run cli + e2e**\n\nRun: `go test ./cmd/kref/ \u0026\u0026 go test -tags e2e ./test/e2e/`\nExpected: PASS. (Update any e2e/cli hooks spec that asserted the old clobber behavior or bare `kref`/`Render()` with no args.)\n\n- [ ] **Step 7: Commit**\n\n```bash\ngit add internal/hooks/hooks.go internal/hooks/hooks_test.go cmd/kref/commands.go go.mod go.sum\ngit commit -m \"feat(hooks): merge into existing lefthook.yml; install uses os.Executable\"\n```\n\n## Task B9: README — ingest \u0026 hooks behavior; final verification\n\n**Files:**\n- Modify: `README.md` (ingest bridge §, hooks §, command reference)\n\n- [ ] **Step 1: Update the ingest-bridge section**\n\nIn README.md's \"The ingest bridge\" section, document idempotency, dirs, and the marker:\n\n```\n`kref ingest \u003cpath\u003e...` reads markdown file(s) — or director(ies), walked\nrecursively for `*.md` — runs a gitleaks scan, and stores each as an entry. On\nthe first ingest kref stamps a `\u003c!-- kref-id: … --\u003e` trailer into the file; a later\ningest of that file **updates the same entry** instead of creating a duplicate\n(unchanged files are a no-op). If a secret is detected in an *unmarked* file the\nentry is quarantined to `private`; in an already-mapped file ingest fails closed\nso the secret never reaches that entry's tier. `--skip-missing` skips paths that\ndo not exist. The store directory (`.kref/`) is gitignored.\n```\n\n- [ ] **Step 2: Update the hooks section**\n\nReplace the `kref hooks install` description block:\n\n```\nkref hooks install     # writes/merges lefthook.yml: post-merge/checkout -\u003e sync pull,\n                     # pre-push -\u003e sync push, post-commit -\u003e ingest changed markdown\n                     # under docs/superpowers/plans, specs, .specify, openspec.\n                     # Hooks call kref by ABSOLUTE PATH; --force MERGES into an\n                     # existing lefthook.yml (your other hooks are preserved).\nkref hooks print       # print the config instead of writing it\n```\n\nAnd update the command-reference line:\n\n```\nkref ingest \u003cpath\u003e... [--tier --skip-missing]  ingest markdown file(s)/dir(s)\nkref hooks install|print [--force]            lefthook wiring (--force merges)\n```\n\n- [ ] **Step 3: Full verification**\n\nRun:\n```bash\ntask check\n```\nExpected: fmt clean, `go vet` clean, all unit + e2e suites PASS. If `task check` runs `test:e2e`, this exercises the binary end to end.\n\n- [ ] **Step 4: Manual smoke (the cranky-user's exact Quickstart)**\n\n```bash\ntmp=$(mktemp -d) \u0026\u0026 ( cd \"$tmp\" \u0026\u0026 git init -q \u0026\u0026 \\\n  \"$(git -C /workspace rev-parse --show-toplevel)/bin/kref\" --dir \"$tmp\" init \u0026\u0026 \\\n  mkdir -p docs/superpowers/plans \u0026\u0026 printf '# Plan\\nv1\\n' \u003e docs/superpowers/plans/p.md \u0026\u0026 \\\n  /workspace/bin/kref --dir \"$tmp\" ingest docs/superpowers/plans \u0026\u0026 \\\n  grep -q 'kref-id' docs/superpowers/plans/p.md \u0026\u0026 echo SMOKE-OK )\n```\nExpected: `SMOKE-OK` — init adopts the repo, ingest stamps the marker. (Build `bin/kref` first with `task build`.)\n\n- [ ] **Step 5: Commit**\n\n```bash\ngit add README.md\ngit commit -m \"docs: document idempotent ingest, dirs, and the merged hooks\"\n```\n\n---\n\n## Self-Review checklist (run before declaring the plan done)\n\n- [ ] **Spec coverage:** D1 (B3), D2 (B4), D3 (B4 fail-closed spec), D4 (B1), D5 (B5/B6), D6 (B7), D7 (B8). Review §5 components all touched. Review findings: P0 init (A1/A2); P1 post-commit (B7), --force clobber (B8), bar