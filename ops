 n\n\t\t\t}\n\t\t}\n\t}\n\n\t// header\n\thdr := make([]string, len(cols))\n\tfor i, c := range cols {\n\t\tif i == len(cols)-1 {\n\t\t\thdr[i] = columnHeaders[c]\n\t\t} else {\n\t\t\thdr[i] = pad(columnHeaders[c], widths[i])\n\t\t}\n\t}\n\tfmt.Fprintln(w, strings.Join(hdr, \"  \"))\n\n\t// rows\n\tfor _, r := range rows {\n\t\tcells := make([]string, len(cols))\n\t\tfor i, c := range cols {\n\t\t\tlast := i == len(cols)-1\n\t\t\tif c == ColTier {\n\t\t\t\twdt := widths[i]\n\t\t\t\tif last {\n\t\t\t\t\twdt = 0 // no trailing pad on the final column\n\t\t\t\t}\n\t\t\t\tcells[i] = tierCell(r.snap.Tier, wdt, color)\n\t\t\t} else if last {\n\t\t\t\tcells[i] = tableCell(c, r)\n\t\t\t} else {\n\t\t\t\tcells[i] = pad(tableCell(c, r), widths[i])\n\t\t\t}\n\t\t}\n\t\tfmt.Fprintln(w, strings.Join(cells, \"  \"))\n\t}\n\n\tnoun := \"entries\"\n\tif len(rows) == 1 {\n\t\tnoun = \"entry\"\n\t}\n\tfmt.Fprintf(w, \"\\n%d %s\\n\", len(rows), noun)\n}\n```\n\n\u003e Delete the now-duplicated original `List` body (the inline header/width/row loop) so only the delegating `List` + the new functions remain. Keep `listRow`, `listRows`, `tierRank`, `tierCell`, `pad`, `tierPlain` as-is.\n\n- [ ] **Step 6: Run the render suite to verify pass + no regressions**\n\nRun: `GOTOOLCHAIN=auto KREF_GITLEAKS=$PWD/bin/gitleaks go test ./internal/render/ -run TestRender`\nExpected: PASS, including the pre-existing default-table specs (byte-identical output for `DefaultColumns`).\n\n- [ ] **Step 7: Commit**\n\n```bash\ngit add internal/render/render.go internal/render/render_test.go\ngit commit -m \"feat(render): column-driven list with TSV plain mode\"\n```\n\n---\n\n### Task 5: `kref list --plain` / `--columns` / `--wide`\n\n**Files:**\n- Modify: `cmd/kref/commands.go` (`newListCmd`: flags, validation, pass column spec to render)\n- Test: `cmd/kref/cli_test.go`\n\n- [ ] **Step 1: Write the failing tests**\n\n```go\nvar _ = Describe(\"list output flags\", func() {\n    seed := func() {\n        run(\"