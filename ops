, err := filepath.Abs(path); err == nil {\n\t\tpath = abs\n\t}\n\tif err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {\n\t\treturn err\n\t}\n\tf, err := os.OpenFile(path, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, 0o644)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif err := sh.gen(cmd.Root(), f, noDesc); err != nil {\n\t\tf.Close()\n\t\treturn err\n\t}\n\tif err := f.Close(); err != nil {\n\t\treturn err\n\t}\n\treturn emit(cmd,\n\t\tfunc(w io.Writer, _ bool) {\n\t\t\tfmt.Fprintf(w, \"Installed completion to %s\\n\", path)\n\t\t\tif sh.installNote != nil {\n\t\t\t\tfmt.Fprintln(w, sh.installNote(filepath.Dir(path)))\n\t\t\t}\n\t\t},\n\t\tmap[string]any{\"shell\": sh.name, \"path\": path, \"installed\": true})\n}\n```\n\nAdd `\"os\"` to the `completion.go` import block:\n\n```go\nimport (\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\n\t\"github.com/spf13/cobra\"\n)\n```\n\n- [ ] **Step 4: Run the tests to verify they pass**\n\nRun: `GOTOOLCHAIN=auto go test ./cmd/kref/ -run TestCLI 2\u003e\u00261 | tail -25`\nExpected: PASS — all install specs green.\n\n- [ ] **Step 5: Full suite + build sanity**\n\nRun: `cd /workspace \u0026\u0026 task test`\nExpected: all suites pass (gitleaks-wired scan tests included).\n\nRun: `cd /workspace \u0026\u0026 GOTOOLCHAIN=auto task build \u0026\u0026 ./bin/kref completion zsh --install --dir /tmp/kref-comp-check \u0026\u0026 cat /tmp/kref-comp-check/_kref | head -2`\nExpected: prints `Installed completion to /tmp/kref-comp-check/_kref` plus the fpath note, and the file starts with `#compdef kref`.\n\n- [ ] **Step 6: Commit**\n\n```bash\ngit add cmd/kref/completion.go cmd/kref/completion_test.go\ngit commit -m \"feat(completion): add --install and --dir to write the script\"\n```\n\n---\n\n## Task 4: Documentation\n\n**Files:**\n- Modify: `README.md` (and any other doc that describes completion setup — search first)\n\n- [ ] **Step 1: Find existing completion docs**\n\nRun: `cd /workspace \u0026\u0026 grep -rni