", \"Beta carotene\", \"delta\"}\n\n\tIt(\"returns case-insensitive matching line indices in order\", func() {\n\t\tExpect(searchMatches(lines, \"beta\")).To(Equal([]int{0, 2}))\n\t})\n\n\tIt(\"returns nil for an empty query or no match\", func() {\n\t\tExpect(searchMatches(lines, \"\")).To(BeNil())\n\t\tExpect(searchMatches(lines, \"zeta\")).To(BeNil())\n\t})\n})\n```\n\n- [ ] **Step 3: Run test to verify it fails**\n\nRun: `go test ./cmd/kref/... -run anything 2\u003e\u00261 | head` (it fails to compile: `searchMatches` undefined)\nExpected: FAIL â€” `searchMatches` undefined.\n\n- [ ] **Step 4: Implement the pager**\n\nReplace `cmd/kref/pager.go` entirely:\n\n```go\npackage main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\n\t\"github.com/charmbracelet/bubbles/viewport\"\n\ttea \"github.com/charmbracelet/bubbletea\"\n\t\"github.com/charmbracelet/lipgloss\"\n)\n\n// searchMatches returns the indices of lines that contain query\n// (case-insensitive), in order. A blank query matches nothing.\nfunc searchMatches(lines []string, query string) []int {\n\tq := strings.ToLower(strings.TrimSpace(query))\n\tif q == \"\" {\n\t\treturn nil\n\t}\n\tvar out []int\n\tfor i, ln := range lines {\n\t\tif strings.Contains(strings.ToLower(ln), q) {\n\t\t\tout = append(out, i)\n\t\t}\n\t}\n\treturn out\n}\n\nvar (\n\ttitleStyle  = lipgloss.NewStyle().Bold(true).Reverse(true).Padding(0, 1)\n\tfooterStyle = lipgloss.NewStyle().Faint(true).Padding(0, 1)\n\tpromptStyle = lipgloss.NewStyle().Bold(true)\n)\n\ntype pagerModel struct {\n\ttitle    string\n\tlines    []string\n\tvp       viewport.Model\n\tready    bool\n\thelpOpen bool\n\n\tsearching bool\n\tquery     string\n\tmatches   []int\n\tmatchIdx  int\n}\n\nfunc newPagerModel(title, content string) pagerModel {\n\treturn pagerModel{title: title, lines: strings.Split(content, \"\\n\")}\n}\n\nfunc (m pagerModel) Init() tea.Cmd { return nil }\n\nfunc (m pagerModel) Update(msg tea.Msg) (tea.Model, tea.Cmd) {\n\tswitch msg := msg.(type) {\n\tcase tea.WindowSizeMsg:\n\t\th := msg.Height - 2 // title + footer\n\t\tif h \u003c 1 {\n\t\t\th = 1\n\t\t}\n\t\tif !m.ready {\n\t\t\tm.vp = viewport.New(msg.Width, h)\n\t\t\tm.vp.SetContent(strings.Join(m.lines, \"\\n\"))\n\t\t\tm.ready = true\n\t\t} else {\n\t\t\tm.vp.Width = msg.Width\n\t\t\tm.vp.Height = h\n\t\t}\n\t\treturn m, nil\n\n\tcase tea.KeyMsg:\n\t\tif m.searching {\n\t\t\treturn m.updateSearchInput(msg)\n\t\t}\n\t\tswitch msg.String() {\n\t\tcase \"q\", \"esc\", \"ctrl+c\":\n\t\t\treturn m, tea.Quit\n\t\tcase \"?\":\n\t\t\tm.helpOpen = !m.helpOpen\n\t\t\treturn m, nil\n\t\tcase \"g\", \"home\":\n\t\t\tm.vp.GotoTop()\n\t\t\treturn m, nil\n\t\tcase \"G\", \"end\":\n\t\t\tm.vp.GotoBottom()\n\t\t\treturn m, nil\n\t\tcase \"/\":\n\t\t\tm.searching = true\n\t\t\tm.query = \"\"\n\t\t\treturn m, nil\n\t\tcase \"n\":\n\t\t\tm.jumpMatch(1)\n\t\t\treturn m, nil\n\t\tcase \"N\":\n\t\t\tm.jumpMatch(-1)\n\t\t\treturn m, nil\n\t\t}\n\t}\n\tvar cmd tea.Cmd\n\tm.vp, cmd = m.vp.Update(msg)\n\treturn m, cmd\n}\n\nfunc (m pagerModel) updateSearchInput(msg tea.KeyMsg) (tea.Model, tea.Cmd) {\n\tswitch msg.String() {\n\tcase \"enter\":\n\t\tm.searching = false\n\t\tm.matches = searchMatches(m.lines, m.query)\n\t\tm.matchIdx = 0\n\t\tif len(m.matches) \u003e 0 {\n\t\t\tm.vp.SetYOffset(m.matches[0])\n\t\t}\n\tcase \"esc\":\n\t\tm.searching = false\n\t\tm.query = \"\"\n\tcase \"backspace\":\n\t\tif m.query != \"\" {\n\t\t\tm.query = m.query[:len(m.query)-1]\n\t\t}\n\tdefault:\n\t\tif len(msg.Runes) \u003e 0 {\n\t\t\tm.query += string(msg.Runes)\n\t\t}\n\t}\n\treturn m, nil\n}\n\nfunc (m *pagerModel) jumpMatch(dir int) {\n\tif len(m.matches) == 0 {\n\t\treturn\n\t}\n\tm.matchIdx = (m.matchIdx + dir + len(m.matches)) % len(m.matches)\n\tm.vp.SetYOffset(m.matches[m.matchIdx])\n}\n\nfunc (m pagerModel) View() string {\n\tif !m.ready {\n\t\treturn \"\\n  loadingâ€¦\"\n\t}\n\ttitle := titleStyle.Render(truncate(m.title, m.vp.Width))\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\", title, m.vp.View(), m.footer())\n}\n\nfunc (m pagerModel) footer() string {\n\tif m.searching {\n\t\treturn promptStyle.Render(\"/\" + m.query)\n\t}\n\tif m.helpOpen {\n\t\treturn footerStyle.Render(\"j/k â†‘â†“ scroll Â· ctrl+d/u page Â· g/G top/bottom Â· / search Â· n/N next/prev Â· q quit\")\n\t}\n\tinfo := fmt.Sprintf(\"%3.0f%%\", m.vp.ScrollPercent()*100)\n\tif len(m.matches) \u003e 0 {\n\t\tinfo = fmt.Sprintf(\"match %d/%d Â· %s\", m.matchIdx+1, len(m.matches), info)\n\t}\n\treturn footerStyle.Render(info + \"  Â·  ? help Â· q quit\")\n}\n\nfunc truncate(s string, w int) string {\n\tif w \u003c= 0 || len(s) \u003c= w {\n\t\treturn s\n\t}\n\tif w \u003c= 1 {\n\t\treturn s[:w]\n\t}\n\treturn s[:w-1] + \"â€¦\"\n}\n\n// Page displays content in a full-screen scrollable pager with search. It runs\n// on the alternate screen and returns when the user quits.\nfunc Page(title, content string) error {\n\tp := tea.NewProgram(\n\t\tnewPagerModel(title, content),\n\t\ttea.WithAltScreen(),\n\t\ttea.WithMouseCellMotion(),\n\t\ttea.WithOutput(os.Stdout),\n\t)\n\t_, err := p.Run()\n\treturn err\n}\n```\n\n- [ ] **Step 5: Run tests to verify they pass**\n\nRun: `go test ./cmd/kref/... \u0026\u0026 go build ./...`\nExpected: PASS (`searchMatches` specs) and clean build.\n\n- [ ] **Step 6: Manual smoke (interactive â€” cannot be unit-tested)**\n\nRun against a temp repo (a real TTY):\n```bash\ntask build\n./bin/kref --dir \"$(mktemp -d)\" init --name Me --email me@example.com\n# add a long entry, then:\n./bin/kref show \u003cid\u003e\n```\nVerify: scroll (j/k, ctrl+d/u, g/G), `/` search + `n`/`N`, `?` help, `q` quit, and that `kref show \u003cid\u003e | cat` (non-TTY) prints rendered text without paging.\n\n\u003e Note on testing scope: the interactive bubbletea loop is verified by this manual smoke and the build; the extractable logic (`searchMatches`) is unit-tested. The gate (`usePager`) guarantees tests and pipes never enter the TUI, keeping the suite deterministic.\n\n- [ ] 